{
  "name": "@fristradar/api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply fristradar-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply fristradar-db --remote",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "drizzle-orm": "^0.38.0",
    "jose": "^6.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250124.0",
    "drizzle-kit": "^0.30.0",
    "wrangler": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
