{
  "name": "@fristradar/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --ip 0.0.0.0",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler d1 migrations apply fristradar-db --remote && wrangler deploy",
    "typecheck": "tsc -b ../../packages/shared && tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply fristradar-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply fristradar-db --remote",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.5.3",
    "@hono/zod-openapi": "^1.2.1",
    "@fristradar/shared": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "drizzle-kit": "^0.31.8",
    "typescript": "~5.7.0",
    "wrangler": "^3.91.0"
  }
}
